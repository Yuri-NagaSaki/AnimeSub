Comment: 0,0:00:00.00,0:00:00.00,OPJP,retimed_syl_dur,0,0,0,code line,syl_fad_s = 500    syl_fad_e = 300    retime_offset_s = 0    retime_offset_e = 0    retimed_syl_dur = line.duration+retime_offset_s+retime_offset_e
Comment: 0,0:00:00.00,0:00:00.00,OPJP,pos_x,0,0,0,code syl,syl_pos_interval = 15   syl_pos_x = line.left + syl.center + (syl.i-1)*syl_pos_interval
