Dialogue: 0,0:24:52.01,0:24:56.02,screen,,0,0,0,,{\blur1\bord1\fs120\fsp15\fnFZFW-ZHENZTJF-L\c&H020103&\3c&H00013A&\pos(960,700)}深沉的記憶
Comment: 0,0:00:00.98,0:00:00.98,screen,,0,0,0,,
Comment: 0,0:00:00.98,0:00:00.98,Default,,0,0,0,,
Dialogue: 0,0:00:02.23,0:00:07.20,Default,,0,0,0,,我皮歐蘭可是特意給你帶了禮物來哦
Dialogue: 0,0:00:08.32,0:00:10.87,Default,,0,0,0,,是個不死之身的怪物
Dialogue: 0,0:00:13.37,0:00:14.79,Default,,0,0,0,,在塔庫納哈
Dialogue: 0,0:00:15.58,0:00:18.33,Default,,0,0,0,,不死遇見了一位少年
Dialogue: 0,0:00:19.33,0:00:21.54,Default,,0,0,0,,少年名叫谷谷
Dialogue: 0,0:00:23.00,0:00:26.80,Default,,0,0,0,,他因為臉部受傷而戴著面具
Dialogue: 0,0:00:28.05,0:00:30.55,Default,,0,0,0,,稱自己為「怪物」
Dialogue: 0,0:00:31.51,0:00:34.56,Default,,0,0,0,,把不死當成自己弟弟一樣照料
Dialogue: 0,0:00:38.27,0:00:43.98,Default,,0,0,0,,與谷谷 皮歐蘭 以及酒爺共同生活
Dialogue: 0,0:00:45.19,0:00:48.44,Default,,0,0,0,,再加上和鈴的交流
Dialogue: 0,0:00:48.90,0:00:52.57,Default,,0,0,0,,給予了不死更多的刺激
Dialogue: 0,0:02:30.13,0:02:31.92,Default,,0,0,0,,我想到個好主意
Dialogue: 0,0:02:32.26,0:02:34.55,Default,,0,0,0,,我也來工作吧 在這裡
Dialogue: 0,0:02:36.18,0:02:37.97,Default,,0,0,0,,妳認真的嗎 小妹妹
Dialogue: 0,0:02:38.30,0:02:41.64,Default,,0,0,0,,是的 還想拜託一件事
Dialogue: 0,0:02:42.10,0:02:44.39,Default,,0,0,0,,可以讓我住在這裡嗎
Dialogue: 0,0:02:46.19,0:02:48.11,Default,,0,0,0,,可以不用給我工資的
Dialogue: 0,0:02:48.52,0:02:50.40,Default,,0,0,0,,這麼可愛的小妹妹
Dialogue: 0,0:02:50.40,0:02:52.40,Default,,0,0,0,,自然是有求必應了
Dialogue: 0,0:02:52.57,0:02:53.61,Default,,0,0,0,,就這麼決定了
Dialogue: 0,0:02:53.86,0:02:56.16,Default,,0,0,0,,那我回去準備下明天過來
Dialogue: 0,0:03:00.58,0:03:03.91,Default,,0,0,0,,讓那女孩來工作真的好嗎 酒爺
Dialogue: 0,0:03:04.16,0:03:06.46,Default,,0,0,0,,沒事的 房間也有
Dialogue: 0,0:03:06.62,0:03:08.42,Default,,0,0,0,,還有其他什麼問題嗎
Dialogue: 0,0:03:08.63,0:03:11.09,Default,,0,0,0,,沒 沒有 我只是…
Dialogue: 0,0:03:12.55,0:03:13.09,Default,,0,0,0,,不死
Dialogue: 0,0:03:13.71,0:03:16.55,Default,,0,0,0,,在那女孩面前你不要展現自己的能力
Dialogue: 0,0:03:16.97,0:03:17.64,Default,,0,0,0,,為什麼
Dialogue: 0,0:03:18.43,0:03:22.18,Default,,0,0,0,,嚇到她會影響店裡的評價的 那就不好了
Dialogue: 0,0:03:22.52,0:03:24.60,Default,,0,0,0,,你這店評價本來就差
Dialogue: 0,0:03:27.44,0:03:28.69,up,,0,0,0,,瞧妳說的
Dialogue: 0,0:03:27.98,0:03:30.48,Default,,0,0,0,,明天開始我會變得幸福嗎
Dialogue: 0,0:03:31.23,0:03:33.07,Default,,0,0,0,,還是說會更加的難受呢
Dialogue: 0,0:03:40.87,0:03:42.41,Default,,0,0,0,,碗碟 收拾完畢
Dialogue: 0,0:03:43.87,0:03:48.46,Default,,0,0,0,,對了 你除了變換形態之外還有其他的能力嗎
Dialogue: 0,0:03:48.79,0:03:50.00,Default,,0,0,0,,不知道
Dialogue: 0,0:03:50.46,0:03:52.30,Default,,0,0,0,,這回答我都聽膩了
Dialogue: 0,0:03:52.55,0:03:55.09,Default,,0,0,0,,給我看看我沒見過的能力吧
Dialogue: 0,0:04:01.89,0:04:03.56,Default,,0,0,0,,厲害 是長槍
Dialogue: 0,0:04:04.18,0:04:06.81,Default,,0,0,0,,從什麼時候開始有這樣的能力的
Dialogue: 0,0:04:07.39,0:04:08.35,Default,,0,0,0,,不知道
Dialogue: 0,0:04:09.15,0:04:11.94,Default,,0,0,0,,想要的時候 就會變出來
Dialogue: 0,0:04:14.07,0:04:17.65,Default,,0,0,0,,那比如 這個碗能變出來嗎
Dialogue: 0,0:04:18.07,0:04:19.07,Default,,0,0,0,,不行
Dialogue: 0,0:04:19.24,0:04:19.95,Default,,0,0,0,,為什麼
Dialogue: 0,0:04:20.70,0:04:21.91,Default,,0,0,0,,不知道
Dialogue: 0,0:04:22.95,0:04:25.83,Default,,0,0,0,,話說我還沒見過不死之身是什麼樣子的
Dialogue: 0,0:04:32.67,0:04:33.59,Default,,0,0,0,,好疼
Dialogue: 0,0:04:34.75,0:04:37.09,Default,,0,0,0,,好厲害 傷口自己癒合了
Dialogue: 0,0:04:41.05,0:04:42.05,Default,,0,0,0,,是一樣的
Dialogue: 0,0:04:42.05,0:04:43.51,Default,,0,0,0,,這不是能變出來嗎
Dialogue: 0,0:04:44.43,0:04:45.43,Default,,0,0,0,,變出來了
Dialogue: 0,0:04:46.02,0:04:47.73,Default,,0,0,0,,是需要什麼前提條件嗎
Dialogue: 0,0:04:48.27,0:04:50.69,Default,,0,0,0,,難道是靠痛覺產生的嗎
Dialogue: 0,0:04:52.65,0:04:53.94,Default,,0,0,0,,比如說這個
Dialogue: 0,0:04:54.52,0:04:57.07,Default,,0,0,0,,感受火熱的話就能變出火來嗎
Dialogue: 0,0:04:59.28,0:05:00.40,Default,,0,0,0,,稍微實驗一下
Dialogue: 0,0:05:10.04,0:05:11.29,Default,,0,0,0,,只有木棒？
Dialogue: 0,0:05:11.29,0:05:12.79,Default,,0,0,0,,沒辦法變出火來嗎
Dialogue: 0,0:05:13.17,0:05:16.21,Default,,0,0,0,,要是可以的話以後生火就很方便了
Dialogue: 0,0:05:20.80,0:05:22.80,Default,,0,0,0,,什麼嘛 你那表情
Dialogue: 0,0:05:23.18,0:05:24.55,Default,,0,0,0,,反正又不會死
Dialogue: 0,0:05:24.76,0:05:26.35,Default,,0,0,0,,有什麼不爽的嗎
Dialogue: 0,0:05:26.85,0:05:29.68,Default,,0,0,0,,要是討厭的話直接說出來就好了 笨蛋
Dialogue: 0,0:05:30.35,0:05:32.06,Default,,0,0,0,,僅僅是個實驗而已
Dialogue: 0,0:05:34.11,0:05:36.52,Default,,0,0,0,,好的 我知道了 記住了
Dialogue: 0,0:06:06.05,0:06:10.10,Default,,0,0,0,,我來了 今天開始請多關照
Dialogue: 0,0:06:10.27,0:06:11.98,Default,,0,0,0,,咦 不死先生呢
Dialogue: 0,0:06:12.27,0:06:17.06,Default,,0,0,0,,早晨就不見了 大概晚飯的時候會回來吧
Dialogue: 0,0:06:17.40,0:06:19.82,Default,,0,0,0,,晚飯可是不死喜歡吃的肉
Dialogue: 0,0:06:20.15,0:06:21.82,Default,,0,0,0,,是嗎 太好了
Dialogue: 0,0:06:22.36,0:06:25.16,Default,,0,0,0,,說起來 胳膊上的傷口怎麼樣了
Dialogue: 0,0:06:25.36,0:06:27.83,Default,,0,0,0,,完全消失估計還需要一段時間
Dialogue: 0,0:06:28.37,0:06:31.62,Default,,0,0,0,,但上次你給我的蜜餞很好吃
Dialogue: 0,0:06:32.91,0:06:36.79,Default,,0,0,0,,三個月前的傷口應該快要痊癒了吧
Dialogue: 0,0:06:37.17,0:06:40.50,Default,,0,0,0,,但她說還沒有 你想想辦法
Dialogue: 0,0:06:41.42,0:06:43.97,Default,,0,0,0,,我有個好東西 你去那邊坐下
Dialogue: 0,0:06:44.76,0:06:46.68,Default,,0,0,0,,嗯？ 你要做什麼
Dialogue: 0,0:07:06.45,0:07:07.45,Default,,0,0,0,,這是什麼
Dialogue: 0,0:07:08.16,0:07:10.20,Default,,0,0,0,,高純度的酒
Dialogue: 0,0:07:10.45,0:07:13.04,Default,,0,0,0,,把這個塗在小鈴的傷口上就行
Dialogue: 0,0:07:13.37,0:07:15.25,Default,,0,0,0,,唉 為什麼是從我的身體裡
Dialogue: 0,0:07:15.75,0:07:17.67,Default,,0,0,0,,我給你增加了一個臟器
Dialogue: 0,0:07:18.04,0:07:22.84,Default,,0,0,0,,在人體內保存的酒會怎樣 我一直很想知道
Dialogue: 0,0:07:23.13,0:07:26.09,Default,,0,0,0,,很稀有的 連行家我都不打算賣
Dialogue: 0,0:07:26.30,0:07:30.72,Default,,0,0,0,,不是 我想知道你為什麼要對我做這種事
Dialogue: 0,0:07:30.97,0:07:35.85,Default,,0,0,0,,幽默和靈光一閃的結果 這就是好奇心的驅使吧
Dialogue: 0,0:07:36.23,0:07:38.40,Default,,0,0,0,,沒事 你不會死的
Dialogue: 0,0:07:44.19,0:07:45.28,Default,,0,0,0,,怎麼了
Dialogue: 0,0:07:45.36,0:07:47.53,Default,,0,0,0,,我要離開這個破地方
Dialogue: 0,0:07:47.91,0:07:49.03,Default,,0,0,0,,店員先生
Dialogue: 0,0:08:06.09,0:08:09.01,Default,,0,0,0,,肚子裡裝著酒？ 為什麼要做這種事
Dialogue: 0,0:08:09.47,0:08:13.22,Default,,0,0,0,,看這孩子快死了 就沒控制住欲望
Dialogue: 0,0:08:13.60,0:08:16.98,Default,,0,0,0,,我覺得這是實現長年以來的夢想的好機會
Dialogue: 0,0:08:17.18,0:08:20.65,Default,,0,0,0,,所以他只是你的新玩具囉
Dialogue: 0,0:08:21.06,0:08:25.11,Default,,0,0,0,,真過份 現在馬上去追 把他肚子裡的東西取出來
Dialogue: 0,0:08:25.40,0:08:29.07,Default,,0,0,0,,可是 我還有工作要做
Dialogue: 0,0:08:29.53,0:08:31.24,Default,,0,0,0,,什麼工作啊
Dialogue: 0,0:08:31.45,0:08:33.62,Default,,0,0,0,,小妹妹妳能去追嗎
Dialogue: 0,0:08:33.95,0:08:35.66,Default,,0,0,0,,誒 我
Dialogue: 0,0:08:37.08,0:08:41.17,Default,,0,0,0,,倒也不是不願意 但我和店員先生不太熟
Dialogue: 0,0:08:41.71,0:08:44.30,Default,,0,0,0,,再說了為什麼非得我去
Dialogue: 0,0:08:46.71,0:08:48.59,Default,,0,0,0,,店員先生離家出走了
Dialogue: 0,0:08:48.88,0:08:51.64,Default,,0,0,0,,你們關係很好吧 不去找他嗎
Dialogue: 0,0:08:51.97,0:08:53.01,Default,,0,0,0,,你很擔心吧
Dialogue: 0,0:08:53.35,0:08:55.51,Default,,0,0,0,,不要 我不擔心
Dialogue: 0,0:08:56.56,0:08:57.89,Default,,0,0,0,,你們吵架了嗎
Dialogue: 0,0:08:58.23,0:09:02.81,Default,,0,0,0,,真傷腦筋 那裡面可是裝著超稀有的酒啊
Dialogue: 0,0:09:02.94,0:09:06.15,Default,,0,0,0,,真是服了 就是因為這個他才離家出走的
Dialogue: 0,0:09:06.44,0:09:11.78,Default,,0,0,0,,谷谷不在的話誰來做飯啊 我嗎
Dialogue: 0,0:09:12.74,0:09:14.03,Default,,0,0,0,,我來做
Dialogue: 0,0:09:28.80,0:09:30.09,Default,,0,0,0,,真難吃
Dialogue: 0,0:09:30.72,0:09:34.47,Default,,0,0,0,,太好了 果然這不是大眾的口味
Dialogue: 0,0:09:34.89,0:09:38.77,Default,,0,0,0,,沒事的 不死先生 放上鹽就好吃了
Dialogue: 0,0:09:42.27,0:09:45.31,Default,,0,0,0,,還是谷谷做的飯最好吃
Dialogue: 0,0:09:45.40,0:09:47.44,Default,,0,0,0,,這會兒他在做什麼呢
Dialogue: 0,0:09:47.73,0:09:51.20,Default,,0,0,0,,嘴上這麼說 結果還不是誰都沒去找他
Dialogue: 0,0:09:56.12,0:09:58.08,Default,,0,0,0,,誰也沒追來找我
Dialogue: 0,0:10:00.12,0:10:02.54,Default,,0,0,0,,算了 我要一個人活下去
Dialogue: 0,0:10:04.12,0:10:06.92,Default,,0,0,0,,首先 必須得把肚子裡的酒弄出來
Dialogue: 0,0:10:14.30,0:10:15.76,Default,,0,0,0,,出來 出來
Dialogue: 0,0:10:23.23,0:10:26.48,Default,,0,0,0,,就是這個 只要把這個拿掉
Dialogue: 0,0:10:46.96,0:10:51.55,Default,,0,0,0,,沒關係 等攢夠了錢 就找醫生來拿掉
Dialogue: 0,0:10:55.68,0:10:58.76,Default,,0,0,0,,快看 那就是傳聞中的…怪物
Dialogue: 0,0:10:59.10,0:11:00.68,Default,,0,0,0,,噓 會被聽見的
Dialogue: 0,0:11:01.14,0:11:04.06,Default,,0,0,0,,真的是他？ 一點也不恐怖嘛
Dialogue: 0,0:11:04.39,0:11:07.19,Default,,0,0,0,,聽說要是看到他的臉 會被殺掉的
Dialogue: 0,0:11:08.23,0:11:11.57,Default,,0,0,0,,你 真的是谷谷嗎
Dialogue: 0,0:11:11.94,0:11:13.53,Default,,0,0,0,,是的 老闆
Dialogue: 0,0:11:14.03,0:11:15.61,Default,,0,0,0,,在這裡幹活倒是沒問題
Dialogue: 0,0:11:16.16,0:11:18.49,Default,,0,0,0,,可你這個面具是怎麼回事
Dialogue: 0,0:11:19.07,0:11:23.16,Default,,0,0,0,,出了點事故 但我身體很健康
Dialogue: 0,0:11:29.96,0:11:31.21,Default,,0,0,0,,看啊
Dialogue: 0,0:11:31.55,0:11:34.38,Default,,0,0,0,,那個瘦小的傢伙就是怪物嗎
Dialogue: 0,0:11:34.67,0:11:36.84,Default,,0,0,0,,真不想跟他扯上關係
Dialogue: 0,0:11:38.14,0:11:41.60,Default,,0,0,0,,辛苦了 一起吃個晚飯怎麼樣
Dialogue: 0,0:11:43.10,0:11:44.10,up,,0,0,0,,等等
Dialogue: 0,0:11:43.14,0:11:45.02,Default,,0,0,0,,喂 快過來坐下
Dialogue: 0,0:11:45.52,0:11:46.56,up,,0,0,0,,好
Dialogue: 0,0:11:46.56,0:11:47.10,Default,,0,0,0,,喂
Dialogue: 0,0:11:48.06,0:11:49.56,Default,,0,0,0,,你為什麼戴著這個
Dialogue: 0,0:11:49.98,0:11:51.44,Default,,0,0,0,,啊 這個是…
Dialogue: 0,0:11:51.82,0:11:53.15,Default,,0,0,0,,因為受過傷
Dialogue: 0,0:11:53.48,0:11:54.32,Default,,0,0,0,,給我看看
Dialogue: 0,0:11:54.86,0:11:56.82,Default,,0,0,0,,不 還是別看了吧
Dialogue: 0,0:11:57.07,0:12:01.41,Default,,0,0,0,,對了谷谷 你哥哥新走了以後就剩你一個人吧
Dialogue: 0,0:12:01.99,0:12:04.83,Default,,0,0,0,,成為我家的一員 住在這裡如何
Dialogue: 0,0:12:05.79,0:12:07.12,Default,,0,0,0,,可 可以嗎
Dialogue: 0,0:12:07.46,0:12:08.92,Default,,0,0,0,,真的假的 爸爸
Dialogue: 0,0:12:09.12,0:12:10.67,Default,,0,0,0,,我才不想跟他住在一起
Dialogue: 0,0:12:11.00,0:12:13.34,Default,,0,0,0,,鎮上的人都說他是怪物
Dialogue: 0,0:12:13.96,0:12:15.38,Default,,0,0,0,,你夠了
Dialogue: 0,0:12:15.71,0:12:17.80,Default,,0,0,0,,說這種話 就不覺得丟臉嗎
Dialogue: 0,0:12:18.43,0:12:21.68,Default,,0,0,0,,鎮上的人怎麼說 又不關谷谷的事
Dialogue: 0,0:12:21.80,0:12:23.56,Default,,0,0,0,,但我不喜歡 就是不喜歡
Dialogue: 0,0:12:24.43,0:12:25.31,Default,,0,0,0,,老闆
Dialogue: 0,0:12:26.43,0:12:28.31,Default,,0,0,0,,小將他說的對
Dialogue: 0,0:12:29.10,0:12:33.32,Default,,0,0,0,,所謂家人 首先要以能否互相關愛為前提
Dialogue: 0,0:12:35.48,0:12:37.15,Default,,0,0,0,,這也是我所希望的
Dialogue: 0,0:12:38.03,0:12:40.24,Default,,0,0,0,,所以 請你們試試
Dialogue: 0,0:12:41.32,0:12:42.83,Default,,0,0,0,,看著我這張臉
Dialogue: 0,0:12:44.37,0:12:45.87,Default,,0,0,0,,你們還能關愛我嗎
Dialogue: 0,0:12:54.84,0:12:57.17,Default,,0,0,0,,看吧 果然是個怪物
Dialogue: 0,0:13:04.14,0:13:04.93,Default,,0,0,0,,谷谷
Dialogue: 0,0:13:05.72,0:13:07.89,Default,,0,0,0,,對不起 我們沒有惡意
Dialogue: 0,0:13:08.56,0:13:10.31,Default,,0,0,0,,希望你明天還能來幹活
Dialogue: 0,0:13:10.94,0:13:13.90,Default,,0,0,0,,請不要因此而討厭我們
Dialogue: 0,0:13:15.69,0:13:18.07,Default,,0,0,0,,谷谷 說點什麼吧
Dialogue: 0,0:13:20.36,0:13:23.12,Default,,0,0,0,,沒關係 我笑著呢
Dialogue: 0,0:13:23.78,0:13:24.66,Default,,0,0,0,,是嗎
Dialogue: 0,0:13:25.03,0:13:27.62,Default,,0,0,0,,明天還請多多關照啦
Dialogue: 0,0:13:34.46,0:13:35.34,Default,,0,0,0,,到手
Dialogue: 0,0:13:35.59,0:13:36.42,Default,,0,0,0,,可怕
Dialogue: 0,0:13:36.42,0:13:38.17,Default,,0,0,0,,快跑 不然會被殺掉哦
Dialogue: 0,0:13:44.34,0:13:45.60,Default,,0,0,0,,真是的
Dialogue: 0,0:13:46.01,0:13:48.35,Default,,0,0,0,,搞什麼啊 過份的傢伙
Dialogue: 0,0:13:49.06,0:13:51.56,Default,,0,0,0,,我要是沒有這個面具…
Dialogue: 0,0:13:54.44,0:13:55.73,Default,,0,0,0,,我沒了它又怎樣
Dialogue: 0,0:13:56.69,0:13:58.40,Default,,0,0,0,,就做不了人了嗎
Dialogue: 0,0:14:28.51,0:14:30.56,Default,,0,0,0,,谷谷 你面具怎麼了
Dialogue: 0,0:14:30.93,0:14:32.10,Default,,0,0,0,,扔掉了
Dialogue: 0,0:14:32.43,0:14:33.10,Default,,0,0,0,,為什麼
Dialogue: 0,0:14:33.52,0:14:36.48,Default,,0,0,0,,戴著太悶 摘了之後清爽多了
Dialogue: 0,0:14:38.15,0:14:39.98,Default,,0,0,0,,這樣啊 原來如此
Dialogue: 0,0:14:40.69,0:14:42.61,Default,,0,0,0,,希望你今天也能好好幹活
Dialogue: 0,0:14:42.99,0:14:43.45,Default,,0,0,0,,是
Dialogue: 0,0:14:45.91,0:14:48.62,Default,,0,0,0,,早上打掃衛生 早上打掃衛生
Dialogue: 0,0:14:52.41,0:14:53.04,Default,,0,0,0,,完事
Dialogue: 0,0:14:54.87,0:14:56.38,Default,,0,0,0,,誰幹的
Dialogue: 0,0:14:59.42,0:15:00.25,Default,,0,0,0,,鹽
Dialogue: 0,0:15:04.09,0:15:06.01,Default,,0,0,0,,鹽放太多了…
Dialogue: 0,0:15:08.01,0:15:11.52,Default,,0,0,0,,耕地到中午 耕地到中午
Dialogue: 0,0:15:14.10,0:15:15.94,Default,,0,0,0,,怎麼成這樣子了
Dialogue: 0,0:15:16.65,0:15:19.86,Default,,0,0,0,,下午看店 下午看店
Dialogue: 0,0:15:29.74,0:15:30.58,Default,,0,0,0,,皮歐蘭
Dialogue: 0,0:15:32.70,0:15:33.54,Default,,0,0,0,,怎麼了
Dialogue: 0,0:15:34.83,0:15:38.42,Default,,0,0,0,,什麼時候會叫我名字了
Dialogue: 0,0:15:39.59,0:15:44.30,Default,,0,0,0,,教我 打掃 做飯 幹活
Dialogue: 0,0:15:44.76,0:15:45.63,Default,,0,0,0,,為什麼
Dialogue: 0,0:15:46.30,0:15:48.72,Default,,0,0,0,,因為什麼都做不好
Dialogue: 0,0:15:49.30,0:15:50.18,Default,,0,0,0,,不要
Dialogue: 0,0:15:50.55,0:15:51.39,Default,,0,0,0,,為什麼
Dialogue: 0,0:15:51.81,0:15:54.43,Default,,0,0,0,,去找谷谷 讓他教你
Dialogue: 0,0:15:55.10,0:15:57.02,Default,,0,0,0,,他比任何人都懂
Dialogue: 0,0:16:04.36,0:16:07.28,Default,,0,0,0,,給我這些也不會教你
Dialogue: 0,0:16:15.37,0:16:16.83,Default,,0,0,0,,為什麼不教他
Dialogue: 0,0:16:17.58,0:16:18.96,Default,,0,0,0,,我不能寵壞它
Dialogue: 0,0:16:19.42,0:16:22.50,Default,,0,0,0,,它必須儘快變成人類
Dialogue: 0,0:16:23.21,0:16:24.05,Default,,0,0,0,,人類？
Dialogue: 0,0:16:33.35,0:16:35.06,up,,0,0,0,,真努力 真努力
Dialogue: 0,0:16:35.72,0:16:37.35,up,,0,0,0,,個頭真小
Dialogue: 0,0:16:42.23,0:16:42.90,Default,,0,0,0,,怎麼
Dialogue: 0,0:16:51.28,0:16:53.12,Default,,0,0,0,,大家都那麼誇張
Dialogue: 0,0:16:53.70,0:16:55.79,Default,,0,0,0,,我有那麼可怕嗎
Dialogue: 0,0:16:56.79,0:16:58.08,Default,,0,0,0,,那些表情…
Dialogue: 0,0:16:58.75,0:17:00.08,Default,,0,0,0,,比我還有意思
Dialogue: 0,0:17:04.59,0:17:06.34,Default,,0,0,0,,肌肉長了一些
Dialogue: 0,0:17:06.80,0:17:08.13,Default,,0,0,0,,肚子也小了點吧
Dialogue: 0,0:17:08.55,0:17:09.17,Default,,0,0,0,,好
Dialogue: 0,0:17:21.02,0:17:22.15,Default,,0,0,0,,幹 幹什麼
Dialogue: 0,0:17:22.77,0:17:23.52,Default,,0,0,0,,小將
Dialogue: 0,0:17:24.23,0:17:25.52,Default,,0,0,0,,你別再來幹活了
Dialogue: 0,0:17:27.15,0:17:29.36,Default,,0,0,0,,我覺得很丟臉啊 你來的話
Dialogue: 0,0:17:31.41,0:17:33.16,Default,,0,0,0,,你真冷酷啊
Dialogue: 0,0:17:33.49,0:17:35.58,Default,,0,0,0,,明明父親人那麼好
Dialogue: 0,0:17:36.20,0:17:38.12,Default,,0,0,0,,嗯 他是個好父親
Dialogue: 0,0:17:38.45,0:17:40.00,Default,,0,0,0,,所以你別再給他添麻煩了
Dialogue: 0,0:17:40.54,0:17:42.08,Default,,0,0,0,,我家又不是怪胎展覽館
Dialogue: 0,0:17:50.55,0:17:52.72,Default,,0,0,0,,唉 那怪物沒來
Dialogue: 0,0:17:52.93,0:17:54.59,Default,,0,0,0,,嗯 他不幹了吧
Dialogue: 0,0:17:54.85,0:17:57.64,Default,,0,0,0,,什麼嘛 明明還挺有趣的
Dialogue: 0,0:17:57.93,0:17:59.22,Default,,0,0,0,,是啊
Dialogue: 0,0:17:59.22,0:17:59.85,Default,,0,0,0,,對吧
Dialogue: 0,0:18:15.87,0:18:17.62,Default,,0,0,0,,謝謝你 老闆
Dialogue: 0,0:18:18.66,0:18:23.71,Default,,0,0,0,,多虧有老闆你這樣的人 我才沒變得精神不正常
Dialogue: 0,0:18:27.63,0:18:29.80,Default,,0,0,0,,錢 就剩這點了啊
Dialogue: 0,0:18:32.22,0:18:33.55,Default,,0,0,0,,怎麼辦啊
Dialogue: 0,0:18:34.26,0:18:35.39,Default,,0,0,0,,請 請問
Dialogue: 0,0:18:36.51,0:18:39.26,Default,,0,0,0,,您這有工作嗎 我什麼都能幹
Dialogue: 0,0:18:39.26,0:18:41.39,Default,,0,0,0,,錢 錢我可沒有
Dialogue: 0,0:18:43.19,0:18:44.60,Default,,0,0,0,,打擾了 請問
Dialogue: 0,0:18:44.60,0:18:47.23,Default,,0,0,0,,你要幹什麼啊 別過來
Dialogue: 0,0:18:47.52,0:18:48.15,Default,,0,0,0,,請問
Dialogue: 0,0:18:48.86,0:18:50.32,Default,,0,0,0,,走開 去 去
Dialogue: 0,0:19:02.08,0:19:03.96,Default,,0,0,0,,終於身無分文了啊
Dialogue: 0,0:19:12.67,0:19:17.22,Default,,0,0,0,,賣掉這個 賣菜這種工作你一生都不用再做了
Dialogue: 0,0:19:20.81,0:19:21.77,Default,,0,0,0,,歡迎光臨
Dialogue: 0,0:19:23.10,0:19:25.44,Default,,0,0,0,,這個 多少錢收
Dialogue: 0,0:19:27.52,0:19:28.31,Default,,0,0,0,,這是…
Dialogue: 0,0:19:28.69,0:19:31.07,Default,,0,0,0,,這個 你從哪弄到的
Dialogue: 0,0:19:33.36,0:19:35.07,Default,,0,0,0,,還是算了 謝謝
Dialogue: 0,0:19:36.20,0:19:37.20,Default,,0,0,0,,這位客人
Dialogue: 0,0:19:38.28,0:19:42.08,Default,,0,0,0,,我到底 是想保護什麼啊
Dialogue: 0,0:19:43.12,0:19:48.00,Default,,0,0,0,,能讓我 回憶起自己曾生而為人的東西？
Dialogue: 0,0:19:51.00,0:19:53.67,Default,,0,0,0,,滾 不准你再進來
Dialogue: 0,0:20:06.81,0:20:07.69,Default,,0,0,0,,哥哥
Dialogue: 0,0:20:08.69,0:20:10.31,Default,,0,0,0,,怎麼瘦成這樣
Dialogue: 0,0:20:11.69,0:20:13.57,Default,,0,0,0,,多可悲啊
Dialogue: 0,0:20:20.66,0:20:23.95,Default,,0,0,0,,把這個賣掉 就能買很多吃的
Dialogue: 0,0:20:30.04,0:20:31.04,Default,,0,0,0,,谷谷？
Dialogue: 0,0:20:37.47,0:20:39.30,Default,,0,0,0,,我沒有哥哥
Dialogue: 0,0:20:47.68,0:20:51.90,Default,,0,0,0,,就算我把那枚戒指賣了 也終歸是個怪物
Dialogue: 0,0:20:52.69,0:20:57.53,Default,,0,0,0,,但哥哥的話 或許能從小混混變成正經人
Dialogue: 0,0:20:59.91,0:21:02.87,Default,,0,0,0,,怪物不需要那枚戒指
Dialogue: 0,0:21:04.74,0:21:06.70,Default,,0,0,0,,我是傻子嗎
Dialogue: 0,0:21:11.50,0:21:13.84,Default,,0,0,0,,算了 這樣就好
Dialogue: 0,0:21:14.75,0:21:18.88,Default,,0,0,0,,這就是怪物谷谷的 我獨有的生存方式
Dialogue: 0,0:21:23.97,0:21:25.18,Default,,0,0,0,,怎…怎麼回事
Dialogue: 0,0:21:26.06,0:21:26.72,up,,0,0,0,,放我出去
Dialogue: 0,0:21:26.97,0:21:28.81,up,,0,0,0,,喂 放我出去
Dialogue: 0,0:21:27.39,0:21:29.98,Default,,0,0,0,,你覺得他能賣多少錢
Dialogue: 0,0:21:30.14,0:21:32.94,Default,,0,0,0,,如果地方找對了應該還挺值錢
Dialogue: 0,0:21:33.77,0:21:35.98,Default,,0,0,0,,住手 放我出去
Dialogue: 0,0:21:36.44,0:21:38.28,Default,,0,0,0,,你不是說什麼都幹嗎
Dialogue: 0,0:21:38.90,0:21:41.40,Default,,0,0,0,,我們正好給你介紹個合適的工作
Dialogue: 0,0:21:41.86,0:21:42.66,Default,,0,0,0,,來人啊
Dialogue: 0,0:21:43.28,0:21:45.16,Default,,0,0,0,,誰來救救我
Dialogue: 0,0:21:55.84,0:21:57.59,Default,,0,0,0,,這…這狗是怎麼回事
Dialogue: 0,0:21:57.88,0:21:58.84,Default,,0,0,0,,別擋道
Dialogue: 0,0:21:58.84,0:21:59.67,Default,,0,0,0,,滾開
Dialogue: 0,0:22:01.76,0:22:02.59,Default,,0,0,0,,不死
Dialogue: 0,0:22:04.18,0:22:06.05,Default,,0,0,0,,少瞧不起人
Dialogue: 0,0:22:23.32,0:22:24.11,Default,,0,0,0,,不死
Dialogue: 0,0:22:24.99,0:22:27.45,Default,,0,0,0,,你一個人來的嗎
Dialogue: 0,0:22:27.62,0:22:29.33,Default,,0,0,0,,不是害怕森林嗎
Dialogue: 0,0:22:30.33,0:22:31.08,Default,,0,0,0,,是害怕
Dialogue: 0,0:22:31.91,0:22:33.08,Default,,0,0,0,,但還是來了
Dialogue: 0,0:22:34.96,0:22:35.83,Default,,0,0,0,,我明白了
Dialogue: 0,0:22:36.59,0:22:41.88,Default,,0,0,0,,我沒有谷谷的話 就成不了大人
Dialogue: 0,0:22:43.88,0:22:44.80,Default,,0,0,0,,你啊
Dialogue: 0,0:22:45.26,0:22:50.06,Default,,0,0,0,,你變身成怪物的時候真是帥呆了
Dialogue: 0,0:22:55.52,0:22:57.94,Default,,0,0,0,,怪物萬歲！
Dialogue: 0,0:24:32.16,0:24:36.54,Default,,0,0,0,,不死獲得了如同兄弟一般的存在
Dialogue: 0,0:24:37.58,0:24:42.96,Default,,0,0,0,,訴說著烙印在記憶深處 內心痛苦的谷谷
Dialogue: 0,0:24:44.46,0:24:47.38,Default,,0,0,0,,哀嘆著自己身不由己的鈴
Dialogue: 0,0:24:48.63,0:24:54.64,Default,,0,0,0,,然而就在三人的感情日漸深厚之時 令人不安的影子出現了
