Dialogue: 0,0:22:35.14,0:22:40.44,STAFF,,0,0,0,,{\blur5\fad(500,500)}本字幕由喵萌奶茶屋製作  僅供交流試看之用  請勿用於商業用途 \N\N翻譯: Oscuro　校對: Dysonsphere　繁化: 雲棋　後期: MIR
Comment: 0,0:00:00.00,0:00:00.00,Default,,0,0,0,,Dialogue
Dialogue: 0,0:01:41.74,0:01:45.17,Default,,0,0,0,,安全帶指示燈已點亮
Dialogue: 0,0:01:45.29,0:01:47.33,Default,,0,0,0,,請繫好安全帶
Dialogue: 0,0:01:48.33,0:01:49.48,Default,,0,0,0,,女士們先生們
Dialogue: 0,0:01:49.66,0:01:52.10,Default,,0,0,0,,機長已點亮安全帶指示燈
Dialogue: 0,0:01:52.34,0:01:54.44,Default,,0,0,0,,請繫好安全帶
Dialogue: 0,0:01:56.64,0:01:59.25,Default,,0,0,0,,武藤女士 身體還好嗎
Dialogue: 0,0:01:59.66,0:02:00.82,Default,,0,0,0,,我沒事 謝謝
Dialogue: 0,0:02:02.55,0:02:05.08,Default,,0,0,0,,此航班將於約15分鐘後
Dialogue: 0,0:02:05.08,0:02:08.12,Default,,0,0,0,,抵達東京羽田國際機場
Dialogue: 0,0:02:34.78,0:02:36.70,Default,,0,0,0,,喂 這邊這邊
Dialogue: 0,0:02:43.67,0:02:44.47,Default,,0,0,0,,媽媽
Dialogue: 0,0:02:44.47,0:02:45.87,Default,,0,0,0,,快來看 這裡有小鳥
Dialogue: 0,0:02:45.98,0:02:49.12,Default,,0,0,0,,是啊 鳥兒們真可愛
Dialogue: 0,0:02:54.47,0:02:56.98,Default,,0,0,0,,大點聲 加油
Dialogue: 0,0:03:04.77,0:03:06.18,Default,,0,0,0,,各就位
Dialogue: 0,0:03:19.20,0:03:20.01,Default,,0,0,0,,預備
Dialogue: 0,0:03:35.15,0:03:37.54,Default,,0,0,0,,四年後我將代表日本出戰
Dialogue: 0,0:03:38.21,0:03:40.21,Default,,0,0,0,,要帶著這樣的決心訓練
Dialogue: 0,0:03:41.36,0:03:42.21,Default,,0,0,0,,四年
Dialogue: 0,0:03:43.49,0:03:44.80,Default,,0,0,0,,真遙遠啊
Dialogue: 0,0:03:46.33,0:03:47.78,Default,,0,0,0,,第二棒 佐藤
Dialogue: 0,0:03:47.78,0:03:48.22,Default,,0,0,0,,收到
Dialogue: 0,0:03:48.69,0:03:50.22,Default,,0,0,0,,第三棒 中山
Dialogue: 0,0:03:50.34,0:03:50.67,Default,,0,0,0,,收到
Dialogue: 0,0:03:51.43,0:03:53.40,Default,,0,0,0,,最後一棒交給我們的王牌 武藤
Dialogue: 0,0:03:53.65,0:03:53.97,Default,,0,0,0,,收到
Dialogue: 0,0:03:54.63,0:03:57.21,Default,,0,0,0,,在接下來的這一場400公尺接力中
Dialogue: 0,0:03:57.26,0:03:59.05,Default,,0,0,0,,妳們這一隊的目標只有冠軍
Dialogue: 0,0:04:01.12,0:04:03.79,Default,,0,0,0,,步 我一定會第一個把棒交給妳的
Dialogue: 0,0:04:05.15,0:04:06.24,Default,,0,0,0,,比賽已經不遠了
Dialogue: 0,0:04:06.39,0:04:08.13,Default,,0,0,0,,沒時間給妳們偷懶的
Dialogue: 0,0:04:08.24,0:04:10.24,Default,,0,0,0,,各位一定要抓緊時間克服缺點
Dialogue: 0,0:04:10.37,0:04:11.76,Default,,0,0,0,,爭取早日取得進步
Dialogue: 0,0:04:12.71,0:04:13.23,Default,,0,0,0,,地震？
Dialogue: 0,0:04:17.24,0:04:18.77,Default,,0,0,0,,大家別慌
Dialogue: 0,0:05:02.53,0:05:03.95,Default,,0,0,0,,晃得真厲害
Dialogue: 0,0:05:05.29,0:05:05.99,Default,,0,0,0,,你說什麼了
Dialogue: 0,0:05:06.60,0:05:07.92,Default,,0,0,0,,沒什麼
Dialogue: 0,0:05:18.69,0:05:19.60,Default,,0,0,0,,情況好點了嗎
Dialogue: 0,0:05:19.68,0:05:21.21,Default,,0,0,0,,還沒有
Dialogue: 0,0:05:21.21,0:05:23.52,Default,,0,0,0,,還在搖個不停呢
Dialogue: 0,0:05:23.99,0:05:25.46,Default,,0,0,0,,震得真久啊
Dialogue: 0,0:05:25.46,0:05:27.18,Default,,0,0,0,,上面沒問題嗎
Dialogue: 0,0:05:28.99,0:05:30.85,Default,,0,0,0,,大伙 沒受傷吧
Dialogue: 0,0:05:31.33,0:05:32.62,Default,,0,0,0,,下面沒問題
Dialogue: 0,0:05:33.10,0:05:34.32,Default,,0,0,0,,我這裡也沒問題
Dialogue: 0,0:05:34.75,0:05:36.33,Default,,0,0,0,,武藤那邊呢
Dialogue: 0,0:05:36.42,0:05:38.89,Default,,0,0,0,,剛剛把我嚇著了
Dialogue: 0,0:05:39.18,0:05:40.83,Default,,0,0,0,,先給他們打個電話吧
Dialogue: 0,0:05:41.41,0:05:43.54,Default,,0,0,0,,手機沒帶上來
Dialogue: 0,0:05:43.82,0:05:45.66,Default,,0,0,0,,武藤膽子太小了
Dialogue: 0,0:05:46.05,0:05:49.08,Default,,0,0,0,,剛剛的地震也就4級左右
Dialogue: 0,0:05:49.37,0:05:52.34,Default,,0,0,0,,好 等把照明設備搭好了就收工
Dialogue: 0,0:05:52.47,0:05:53.15,Default,,0,0,0,,收到
Dialogue: 0,0:05:53.15,0:05:53.93,Default,,0,0,0,,真棒
Dialogue: 0,0:06:02.91,0:06:04.81,Default,,0,0,0,,剛剛東京發生地震
Dialogue: 0,0:06:04.81,0:06:06.92,Default,,0,0,0,,我們正確定跑道的安全
Dialogue: 0,0:06:06.92,0:06:08.48,Default,,0,0,0,,飛機將推遲降落
Dialogue: 0,0:06:15.09,0:06:17.97,Default,,0,0,0,,鐵路已緊急停止通行
Dialogue: 0,0:06:18.07,0:06:20.20,Default,,0,0,0,,正在進行安全檢查
Dialogue: 0,0:06:35.87,0:06:36.83,Default,,0,0,0,,好劇烈的地震
Dialogue: 0,0:06:37.19,0:06:37.65,Default,,0,0,0,,是啊
Dialogue: 0,0:06:39.58,0:06:41.13,Default,,0,0,0,,震源是在哪呢
Dialogue: 0,0:06:41.13,0:06:42.85,Default,,0,0,0,,電車不會停運了吧
Dialogue: 0,0:06:44.46,0:06:46.12,Default,,0,0,0,,嗯 是啊
Dialogue: 0,0:06:46.12,0:06:47.82,Default,,0,0,0,,這是我遇到過最大的地震了
Dialogue: 0,0:06:47.82,0:06:49.14,Default,,0,0,0,,我記得妳是四國出身的吧
Dialogue: 0,0:06:49.14,0:06:51.30,Default,,0,0,0,,好了 今天的練習到此結束
Dialogue: 0,0:06:51.57,0:06:53.54,Default,,0,0,0,,大家先聯繫一下家裡人
Dialogue: 0,0:06:53.71,0:06:55.89,Default,,0,0,0,,換好衣服後到正門集合
Dialogue: 0,0:06:55.89,0:06:56.41,Default,,0,0,0,,是
Dialogue: 0,0:07:01.15,0:07:02.93,Default,,0,0,0,,我還是第一次遇到地震
Dialogue: 0,0:07:03.06,0:07:03.90,Default,,0,0,0,,我已經習慣了
Dialogue: 0,0:07:04.01,0:07:05.94,Default,,0,0,0,,畢竟關東地區地震頻發啊
Dialogue: 0,0:07:06.12,0:07:07.54,Default,,0,0,0,,感覺真奇怪
Dialogue: 0,0:07:08.42,0:07:09.44,Default,,0,0,0,,LINE發出去了
Dialogue: 0,0:07:09.44,0:07:10.83,Default,,0,0,0,,已讀了
Dialogue: 0,0:07:12.09,0:07:15.76,Default,,0,0,0,,電車果然停運了 不要啊
Dialogue: 0,0:07:16.09,0:07:18.07,Default,,0,0,0,,東京震級是5弱啊
Dialogue: 0,0:07:18.07,0:07:19.47,Default,,0,0,0,,果然還是挺大的
Dialogue: 0,0:07:20.43,0:07:22.43,Default,,0,0,0,,沖繩居然是7級
Dialogue: 0,0:07:23.24,0:07:25.43,Default,,0,0,0,,7級已經是最高了吧
Dialogue: 0,0:07:25.43,0:07:27.07,Default,,0,0,0,,聽起來好嚴重啊
Dialogue: 0,0:07:32.44,0:07:33.71,Default,,0,0,0,,地震又要來了嗎
Dialogue: 0,0:07:33.91,0:07:35.51,Default,,0,0,0,,只是剛剛的餘震啦
Dialogue: 0,0:07:48.90,0:07:49.75,Default,,0,0,0,,什麼聲音
Dialogue: 0,0:08:01.68,0:08:02.94,Default,,0,0,0,,檢查完畢
Dialogue: 0,0:08:03.34,0:08:04.67,Default,,0,0,0,,我也撤了吧
Dialogue: 0,0:09:19.99,0:09:21.38,Default,,0,0,0,,救命
Dialogue: 0,0:09:26.56,0:09:28.86,Default,,0,0,0,,誰來
Dialogue: 0,0:09:29.72,0:09:31.01,Default,,0,0,0,,救救我
Dialogue: 0,0:09:51.55,0:09:52.24,Default,,0,0,0,,大伙
Dialogue: 0,0:10:00.63,0:10:03.06,Default,,0,0,0,,地震來了的時候要是你在一樓
Dialogue: 0,0:10:03.06,0:10:04.09,Default,,0,0,0,,就趕緊跑到外面去
Dialogue: 0,0:10:04.59,0:10:04.97,Default,,0,0,0,,知道了嗎
Dialogue: 0,0:10:09.08,0:10:11.71,Default,,0,0,0,,爸 媽
Dialogue: 0,0:10:30.24,0:10:32.62,Default,,0,0,0,,每次媽媽回來的時候
Dialogue: 0,0:10:32.62,0:10:33.82,Default,,0,0,0,,我們都會開車遠行
Dialogue: 0,0:10:34.18,0:10:35.88,Default,,0,0,0,,一起到外面吃飯
Dialogue: 0,0:10:37.37,0:10:39.86,Default,,0,0,0,,想吃海鮮的時候 我們會去港口
Dialogue: 0,0:10:40.11,0:10:42.38,Default,,0,0,0,,因為那邊有十分美味的專營店
Dialogue: 0,0:10:42.44,0:10:45.09,Default,,0,0,0,,不管要花多長時間 我們都會過去
Dialogue: 0,0:10:45.93,0:10:49.26,Default,,0,0,0,,我們對鮮美可口的料理欲罷不能
Dialogue: 0,0:11:08.73,0:11:11.64,Default,,0,0,0,,請蜷曲身體 保持前傾
Dialogue: 0,0:11:08.10,0:11:11.40,Top,,0,0,0,,因無法繼續飛行 我們將在水面緊急迫降
Dialogue: 0,0:11:11.64,0:11:13.53,Top,,0,0,0,,請做好防衝擊姿勢
Dialogue: 0,0:11:30.81,0:11:33.77,Default,,0,0,0,,你們一定不要出事啊
Dialogue: 0,0:12:18.49,0:12:19.86,Default,,0,0,0,,大家請冷靜
Dialogue: 0,0:12:20.55,0:12:21.39,Default,,0,0,0,,慌什麼慌
Dialogue: 0,0:12:21.92,0:12:24.36,Default,,0,0,0,,大家請按順序依次上船
Dialogue: 0,0:12:29.78,0:12:30.57,Default,,0,0,0,,妳推什麼啊推
Dialogue: 0,0:12:30.57,0:12:31.90,Default,,0,0,0,,我還帶著孩子啊
Dialogue: 0,0:12:31.90,0:12:33.06,Default,,0,0,0,,我不也帶著孩子嗎
Dialogue: 0,0:12:34.04,0:12:35.35,Default,,0,0,0,,趕緊發船
Dialogue: 0,0:12:35.91,0:12:38.64,Default,,0,0,0,,這飛機不知道什麼時候就爆炸了
Dialogue: 0,0:12:37.81,0:12:38.64,Top,,0,0,0,,那是什麼
Dialogue: 0,0:12:39.14,0:12:40.15,Default,,0,0,0,,海嘯
Dialogue: 0,0:12:40.15,0:12:41.59,Default,,0,0,0,,大家快上岸
Dialogue: 0,0:12:51.89,0:12:53.12,Default,,0,0,0,,爸爸
Dialogue: 0,0:13:05.23,0:13:07.80,Default,,0,0,0,,放心吧 有阿姨在呢
Dialogue: 0,0:14:03.36,0:14:04.59,Default,,0,0,0,,打不通
Dialogue: 0,0:14:16.13,0:14:17.38,Default,,0,0,0,,大家別出事啊
Dialogue: 0,0:14:29.80,0:14:30.70,Default,,0,0,0,,打起精神來
Dialogue: 0,0:14:31.19,0:14:33.11,Default,,0,0,0,,回去了一定能找到大家的
Dialogue: 0,0:14:38.42,0:14:39.79,Default,,0,0,0,,我們家新修的房子
Dialogue: 0,0:14:39.79,0:14:42.79,Default,,0,0,0,,是父親精心設計的
Dialogue: 0,0:14:43.08,0:14:44.26,Default,,0,0,0,,我也感到很自豪
Dialogue: 0,0:14:45.18,0:14:45.82,Default,,0,0,0,,但是
Dialogue: 0,0:14:46.12,0:14:48.88,Default,,0,0,0,,院子裡栽的樹上裝著花裡胡哨的燈光
Dialogue: 0,0:14:49.24,0:14:51.19,Default,,0,0,0,,害得我們成了鄰居裡的名人
Dialogue: 0,0:14:51.19,0:14:52.47,Default,,0,0,0,,這讓我很不好意思
Dialogue: 0,0:14:53.19,0:14:56.45,Default,,0,0,0,,雖然我很喜歡自己房間裡的大窗戶
Dialogue: 0,0:14:56.89,0:14:58.11,Default,,0,0,0,,但是一到晚上
Dialogue: 0,0:14:58.11,0:15:00.54,Default,,0,0,0,,窗簾就會映上五顏六色的燈光
Dialogue: 0,0:15:06.23,0:15:08.22,Default,,0,0,0,,早苗 美幸
Dialogue: 0,0:15:07.51,0:15:08.90,Top,,0,0,0,,小昭 小昭
Dialogue: 0,0:15:08.43,0:15:09.40,Default,,0,0,0,,詩織
Dialogue: 0,0:15:09.90,0:15:11.12,Default,,0,0,0,,小圓
Dialogue: 0,0:15:10.51,0:15:12.29,Top,,0,0,0,,這裡是我佔了的
Dialogue: 0,0:15:13.15,0:15:14.74,Default,,0,0,0,,武藤剛在嗎
Dialogue: 0,0:15:15.70,0:15:16.37,Default,,0,0,0,,武藤
Dialogue: 0,0:15:18.30,0:15:19.33,Default,,0,0,0,,這是我撿到的
Dialogue: 0,0:15:19.33,0:15:20.57,Default,,0,0,0,,別想獨吞
Dialogue: 0,0:15:22.20,0:15:24.36,Default,,0,0,0,,武藤航一郎在嗎
Dialogue: 0,0:15:26.44,0:15:27.58,Default,,0,0,0,,武藤瑪麗
Dialogue: 0,0:15:32.92,0:15:34.92,Default,,0,0,0,,大家都在哪啊
Dialogue: 0,0:15:42.58,0:15:43.53,Default,,0,0,0,,那是
Dialogue: 0,0:15:48.47,0:15:49.10,Default,,0,0,0,,妳好
Dialogue: 0,0:15:50.08,0:15:52.56,Default,,0,0,0,,能借我用下手機嗎
Dialogue: 0,0:15:51.53,0:15:52.56,Top,,0,0,0,,別胡說八道了
Dialogue: 0,0:15:52.94,0:15:54.05,Default,,0,0,0,,妳傻嗎
Dialogue: 0,0:15:57.74,0:15:59.33,Default,,0,0,0,,那是什麼
Dialogue: 0,0:16:12.52,0:16:14.96,Default,,0,0,0,,那個燈彩
Dialogue: 0,0:16:16.01,0:16:18.20,Default,,0,0,0,,一定是
Dialogue: 0,0:16:47.48,0:16:48.64,Default,,0,0,0,,爸爸
Dialogue: 0,0:16:49.39,0:16:50.21,Default,,0,0,0,,步
Dialogue: 0,0:16:55.49,0:16:58.35,Default,,0,0,0,,步 妳沒事太好了
Dialogue: 0,0:16:58.69,0:16:59.97,Default,,0,0,0,,爸爸也是
Dialogue: 0,0:16:59.97,0:17:01.51,Default,,0,0,0,,看到剛了嗎
Dialogue: 0,0:17:01.59,0:17:03.38,Default,,0,0,0,,我回家看了 沒找到他
Dialogue: 0,0:17:03.38,0:17:05.63,Default,,0,0,0,,我也回家去了 也沒找到
Dialogue: 0,0:17:05.95,0:17:07.95,Default,,0,0,0,,他不在家裡吧
Dialogue: 0,0:17:08.28,0:17:08.71,Default,,0,0,0,,嗯
Dialogue: 0,0:17:20.59,0:17:22.17,Default,,0,0,0,,和我們家院子裡的是一樣的呢
Dialogue: 0,0:17:22.59,0:17:24.88,Default,,0,0,0,,嗯 在大家都到齊之前
Dialogue: 0,0:17:24.88,0:17:25.71,Default,,0,0,0,,我是不會關燈的
Dialogue: 0,0:17:31.76,0:17:33.83,Default,,0,0,0,,這裡震得比東北還厲害
Dialogue: 0,0:17:34.57,0:17:36.21,Default,,0,0,0,,東京都震成這個樣子了
Dialogue: 0,0:17:36.53,0:17:38.10,Default,,0,0,0,,其他縣也不會好吧
Dialogue: 0,0:17:39.29,0:17:41.05,Default,,0,0,0,,日本 要完蛋了吧
Dialogue: 0,0:17:49.77,0:17:51.06,Default,,0,0,0,,古賀學長
Dialogue: 0,0:17:54.58,0:17:55.56,Default,,0,0,0,,小步
Dialogue: 0,0:17:55.99,0:17:57.25,Default,,0,0,0,,妳果然在這裡
Dialogue: 0,0:17:58.02,0:17:59.07,Default,,0,0,0,,七海姐
Dialogue: 0,0:18:00.54,0:18:01.43,Default,,0,0,0,,小剛
Dialogue: 0,0:18:01.72,0:18:02.74,Default,,0,0,0,,是姐姐嗎
Dialogue: 0,0:18:04.82,0:18:06.25,Default,,0,0,0,,你眼睛怎麼了
Dialogue: 0,0:18:06.74,0:18:07.70,Default,,0,0,0,,我不記得了
Dialogue: 0,0:18:08.27,0:18:09.94,Default,,0,0,0,,我趕到的時候
Dialogue: 0,0:18:10.07,0:18:11.54,Default,,0,0,0,,他雙眼上就已經全是血了
Dialogue: 0,0:18:11.80,0:18:12.51,Default,,0,0,0,,媽媽呢
Dialogue: 0,0:18:12.73,0:18:14.02,Default,,0,0,0,,還沒見到她
Dialogue: 0,0:18:14.25,0:18:15.30,Default,,0,0,0,,可能返航了
Dialogue: 0,0:18:26.45,0:18:28.68,Default,,0,0,0,,眼球沒事 只是眼瞼破了
Dialogue: 0,0:18:29.81,0:18:30.56,Default,,0,0,0,,太好了
Dialogue: 0,0:18:30.80,0:18:32.56,Default,,0,0,0,,不愧是遊戲玩家
Dialogue: 0,0:18:32.75,0:18:34.09,Default,,0,0,0,,靠著迅速的反應
Dialogue: 0,0:18:34.09,0:18:36.63,Default,,0,0,0,,避開了最差的情況
Dialogue: 0,0:18:37.18,0:18:37.89,Default,,0,0,0,,別動
Dialogue: 0,0:18:38.00,0:18:38.50,Default,,0,0,0,,等等
Dialogue: 0,0:18:39.33,0:18:40.06,Default,,0,0,0,,痛
Dialogue: 0,0:18:47.33,0:18:49.12,Default,,0,0,0,,像耳釘一樣 挺帥的
Dialogue: 0,0:18:49.23,0:18:50.02,Default,,0,0,0,,哪裡帥了
Dialogue: 0,0:18:50.02,0:18:53.81,Default,,0,0,0,,步 妳真是和媽媽一樣樂觀啊
Dialogue: 0,0:18:54.51,0:18:56.11,Default,,0,0,0,,我和她才不一樣呢
Dialogue: 0,0:18:56.59,0:18:58.95,Default,,0,0,0,,你就這麼不想和我一樣嗎
Dialogue: 0,0:18:59.99,0:19:00.79,Default,,0,0,0,,瑪麗
Dialogue: 0,0:19:00.90,0:19:01.39,Default,,0,0,0,,媽
Dialogue: 0,0:19:03.37,0:19:04.28,Default,,0,0,0,,媽媽
Dialogue: 0,0:19:06.58,0:19:08.60,Default,,0,0,0,,歡迎回來 妳沒事吧
Dialogue: 0,0:19:08.90,0:19:10.43,Default,,0,0,0,,嗯 勉勉強強
Dialogue: 0,0:19:11.22,0:19:12.83,Default,,0,0,0,,太好了 大家都沒事
Dialogue: 0,0:20:10.30,0:20:11.95,Default,,0,0,0,,一路上真驚險啊
Dialogue: 0,0:20:12.12,0:20:12.62,Default,,0,0,0,,是啊
Dialogue: 0,0:20:13.70,0:20:15.61,Default,,0,0,0,,但是能和大家團聚
Dialogue: 0,0:20:15.70,0:20:17.42,Default,,0,0,0,,只要還活著我就已經很滿足了
Dialogue: 0,0:20:18.01,0:20:19.21,Default,,0,0,0,,我們要不
Dialogue: 0,0:20:20.05,0:20:21.51,Default,,0,0,0,,來拍張合照吧
Dialogue: 0,0:20:21.99,0:20:22.95,Default,,0,0,0,,現在嗎
Dialogue: 0,0:20:23.45,0:20:25.56,Default,,0,0,0,,我可不想這張臉被拍進照片
Dialogue: 0,0:20:25.75,0:20:27.62,Default,,0,0,0,,像耳釘一樣多帥啊
Dialogue: 0,0:20:28.18,0:20:28.60,Default,,0,0,0,,來吧
Dialogue: 0,0:20:29.22,0:20:31.89,Default,,0,0,0,,七海和春生也都過來
Dialogue: 0,0:20:32.41,0:20:33.56,Default,,0,0,0,,我來拍吧
Dialogue: 0,0:20:41.46,0:20:42.64,Default,,0,0,0,,那拍了喔
Dialogue: 0,0:20:44.41,0:20:45.42,Default,,0,0,0,,七
Dialogue: 0,0:20:47.01,0:20:48.24,Default,,0,0,0,,謝謝
Dialogue: 0,0:20:48.71,0:20:49.49,Default,,0,0,0,,拍得正好
Dialogue: 0,0:20:49.95,0:20:52.21,Default,,0,0,0,,應該是一張不錯的全家福喔
Dialogue: 0,0:20:52.53,0:20:53.24,Default,,0,0,0,,謝謝
Dialogue: 0,0:20:54.62,0:20:58.51,Default,,0,0,0,,我後悔以前沒拍全家福
Dialogue: 0,0:20:58.94,0:21:01.66,Default,,0,0,0,,七海姐的老家是在福岡吧
Dialogue: 0,0:21:01.94,0:21:03.17,Default,,0,0,0,,沒錯
Dialogue: 0,0:21:03.73,0:21:07.66,Default,,0,0,0,,七海和春生一定能和家人團聚的
Dialogue: 0,0:21:08.28,0:21:09.57,Default,,0,0,0,,我保證
Dialogue: 0,0:21:10.15,0:21:11.26,Default,,0,0,0,,我相信
Dialogue: 0,0:21:12.87,0:21:13.59,Default,,0,0,0,,喂
Dialogue: 0,0:21:13.59,0:21:15.26,Default,,0,0,0,,好像有訊號了
Dialogue: 0,0:21:15.87,0:21:16.37,Default,,0,0,0,,真的
Dialogue: 0,0:21:16.37,0:21:16.77,Default,,0,0,0,,真的嗎
Dialogue: 0,0:21:18.21,0:21:18.94,Default,,0,0,0,,小步
Dialogue: 0,0:21:19.81,0:21:20.86,Default,,0,0,0,,妳帶手機了嗎
Dialogue: 0,0:21:21.27,0:21:22.75,Default,,0,0,0,,帶了 請用
Dialogue: 0,0:21:23.34,0:21:24.11,Default,,0,0,0,,謝謝
Dialogue: 0,0:21:27.28,0:21:29.28,Default,,0,0,0,,我忘記拿手機了
Dialogue: 0,0:21:29.61,0:21:30.86,Default,,0,0,0,,我也是
Dialogue: 0,0:21:30.86,0:21:31.63,Default,,0,0,0,,我手機在外套裡
Dialogue: 0,0:21:31.63,0:21:33.03,Default,,0,0,0,,不知道什麼時候一起弄丟了
Dialogue: 0,0:21:33.28,0:21:34.93,Default,,0,0,0,,要是從家裡帶來就好了
Dialogue: 0,0:21:35.33,0:21:36.53,Default,,0,0,0,,太熱了我才不要
Dialogue: 0,0:21:41.00,0:21:41.48,Default,,0,0,0,,步
Dialogue: 0,0:21:41.88,0:21:42.41,Default,,0,0,0,,步
Dialogue: 0,0:21:44.81,0:21:45.29,Default,,0,0,0,,妳怎麼了
Dialogue: 0,0:21:48.72,0:21:51.64,Default,,0,0,0,,我把社團裡的同學丟在那裡了
Dialogue: 0,0:21:53.50,0:21:55.19,Default,,0,0,0,,看著她們那麼痛苦
Dialogue: 0,0:21:55.80,0:21:57.12,Default,,0,0,0,,我卻什麼都做不到
Dialogue: 0,0:21:58.45,0:21:59.62,Default,,0,0,0,,反而逃了出來
Dialogue: 0,0:22:02.60,0:22:03.69,Default,,0,0,0,,我也是一樣
Dialogue: 0,0:22:04.01,0:22:04.64,Default,,0,0,0,,不是
Dialogue: 0,0:22:05.83,0:22:09.78,Default,,0,0,0,,不但如此還去拿了自己的手機
Dialogue: 0,0:22:10.30,0:22:11.08,Default,,0,0,0,,步
Dialogue: 0,0:22:11.08,0:22:14.00,Default,,0,0,0,,沒了手機就誰也聯繫不上
Dialogue: 0,0:22:14.49,0:22:16.74,Default,,0,0,0,,我不能不帶上
Dialogue: 0,0:22:18.47,0:22:19.33,Default,,0,0,0,,我明白
Dialogue: 0,0:22:19.78,0:22:22.36,Default,,0,0,0,,多虧了妳七海才能聯繫上家裡
Dialogue: 0,0:22:25.58,0:22:29.03,Default,,0,0,0,,我是不是 太無情了
Dialogue: 0,0:22:29.96,0:22:31.17,Default,,0,0,0,,不論發生了什麼事
Dialogue: 0,0:22:31.89,0:22:34.41,Default,,0,0,0,,只要妳還活著我就很開心了
Dialogue: 0,0:22:47.84,0:22:48.66,Default,,0,0,0,,發生了什麼事
Dialogue: 0,0:22:53.44,0:22:54.07,Default,,0,0,0,,直升機
Dialogue: 0,0:22:54.42,0:22:55.73,Default,,0,0,0,,從那裡落下來的嗎
Dialogue: 0,0:22:55.82,0:22:57.11,Default,,0,0,0,,有什麼掛在上面
Dialogue: 0,0:23:05.60,0:23:07.28,Default,,0,0,0,,到底是怎麼了
Dialogue: 0,0:23:15.50,0:23:16.14,Default,,0,0,0,,那是什麼
