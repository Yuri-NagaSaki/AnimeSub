Dialogue: 0,0:21:52.73,0:21:56.08,EDJP,,0,0,0,,
Dialogue: 0,0:21:56.08,0:21:59.03,EDJP,,0,0,0,,
Dialogue: 0,0:21:59.03,0:22:02.31,EDJP,,0,0,0,,
Dialogue: 0,0:22:02.31,0:22:07.93,EDJP,,0,0,0,,
Dialogue: 0,0:22:08.69,0:22:12.82,EDJP,,0,0,0,,
